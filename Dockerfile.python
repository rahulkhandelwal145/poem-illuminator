# ARG REQUIREMENTS selects CPU (default/local) or CUDA (prod/Azure GPU)
ARG REQUIREMENTS=requirements.cpu.txt
FROM python:3.11-slim
ARG REQUIREMENTS=requirements.cpu.txt
WORKDIR /app
COPY ${REQUIREMENTS} requirements.txt
RUN pip install --no-cache-dir -r requirements.txt
COPY src/createimage.py .
EXPOSE 8083
CMD ["uvicorn", "createimage:app", "--host", "0.0.0.0", "--port", "8083"]
